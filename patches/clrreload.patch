+void
+reload_colors(const Arg *arg)
+{
+    FILE *f = fopen(colors_dir, "r");
+    if (!f) {
+        return;
+    }
+
+    for (int i = 0; i < (int)LENGTH(colors); i++) {
+        unsigned int fg, bg, border;
+        if (fscanf(f, "%x %x %x", &fg, &bg, &border) != 3) {
+            break;
+        }
+        colors[i][ColFg] = fg;
+        colors[i][ColBg] = bg;
+        colors[i][ColBorder] = border;
+    }
+
+    fclose(f);
+    drawbars();
+}
